# Public site URL — used for canonical/OG/RSS tags
NEXT_PUBLIC_SITE_URL=https://www.vendingpreneurs.com

# Supabase (Slice 3b — News CMS). Project: vending-website under AIMS.
# Pull from Vercel with: vercel env pull
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-jwt>
# server-only — never ship to the browser. Vercel: marked --sensitive.
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

# Dangerous local development helper. Only honored under `next dev`; never set in production.
ADMIN_DEV_AUTH_BYPASS=0

# Lead capture notifications. Public forms always store Supabase audit rows
# first; these server-only values control follow-up notifications.
RESEND_API_KEY=<resend-api-key>
LEAD_NOTIFICATION_TO=team@example.com
LEAD_NOTIFICATION_FROM=Vendingpreneurs <leads@example.com>
# Optional
# LEAD_NOTIFICATION_SUBJECT_PREFIX=Vendingpreneurs
# SLACK_WEBHOOK_URL=

# Close CRM sync. `CLOSE_API_KEY` enables the runner; the remaining values map
# qualification/lifecycle fields into this workspace's Close schema.
CLOSE_API_KEY=<close-api-key>
# Optional defaults/config
# CLOSE_API_BASE_URL=https://api.close.com/api/v1
# CLOSE_LEAD_STATUS_ID=
# CLOSE_FOLLOW_UP_ASSIGNED_TO=
# CLOSE_QUALIFICATION_STATUS_FIELD_ID=
# CLOSE_SOURCE_PATH_FIELD_ID=
# CLOSE_EXPERIMENT_KEY_FIELD_ID=
# CLOSE_VARIANT_KEY_FIELD_ID=
# CLOSE_STATE_MARKET_FIELD_ID=
# CLOSE_BUSINESS_STAGE_FIELD_ID=
# CLOSE_BUDGET_RANGE_FIELD_ID=
# CLOSE_AVAILABLE_CAPITAL_FIELD_ID=
# CLOSE_PURCHASE_TIMELINE_FIELD_ID=
# CLOSE_LOCATION_STATUS_FIELD_ID=
# CLOSE_MACHINE_GOAL_FIELD_ID=
# CLOSE_PRIMARY_GOAL_FIELD_ID=
# CLOSE_CONSENT_STATUS_FIELD_ID=
# CLOSE_LATEST_COMPLETED_AT_FIELD_ID=

# SEO Page Builder AI proposal agent. Server-only; never expose with NEXT_PUBLIC_.
OPENAI_API_KEY=<openai-project-api-key>
OPENAI_SEO_MODEL=gpt-5.5
OPENAI_SEO_REASONING_EFFORT=medium

# Slice 0 polish — pending Q8 (analytics)
# NEXT_PUBLIC_GA_ID=

# Sentry error monitoring. The DSN is safe to expose publicly; set both values
# when enabling browser and server/edge reporting. Source map upload also needs
# SENTRY_AUTH_TOKEN, SENTRY_ORG, and SENTRY_PROJECT in CI/Vercel.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
