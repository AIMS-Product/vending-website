# Public site URL — used for canonical/OG tags
NEXT_PUBLIC_SITE_URL=https://vendingpreneurs.com

# Supabase (Slice 3b — News CMS). Project: vending-website under AIMS.
# Pull from Vercel with: vercel env pull
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-jwt>
# server-only — never ship to the browser. Vercel: marked --sensitive.
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

